---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import ThemeScript from '../components/ThemeScript.astro';
import favicon from '../assets/favicon.svg';
import favicon96 from '../assets/favicon-96x96.png';
import faviconIco from '../assets/favicon.ico';
import appleIcon from '../assets/apple-touch-icon.png';
import siteManifest from '../assets/site.webmanifest';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <ThemeScript />
    <title>Research — William L. Anderson</title>
    <link rel="icon" type="image/png" href={favicon96.src} sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <link rel="shortcut icon" href={faviconIco.src} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleIcon.src} />
    <link rel="manifest" href={siteManifest.src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="container">
      <header class="subheader">
        <a href="/" class="subheader-name">William L. Anderson</a>
        <Nav />
      </header>

      <h1 class="page-title">Research</h1>

      <hr class="rule ornament" />

      <section>
        <p>My work focuses on the security risks that arise as increasingly capable AI agents proliferate and come into contact with one another. My technical work focuses on <a href="https://arxiv.org/abs/2505.02077" target="_blank" rel="noopener noreferrer">multi-agent security</a>, and my policy work focuses on the national security implications of AI.</p>
        <ul>
          <li>I'm a MATS Fellow in the Multiagent Security stream with <a href="https://wittlab.ai/author/christian-schroeder-de-witt/" target="_blank" rel="noopener noreferrer">Dr. Christian Schroeder de Witt</a>.</li>
          <li>I was a 2025 Summer Research Fellow at UChicago's Existential Risk Lab, where I worked on subtle attacks<sup class="note" tabindex="0" data-note="Attacks where the adversarial signal is distributed across many interactions, so no single exchange looks malicious on its own.">*</sup> on multi-agent systems in critical infrastructure, advised by <a href="https://lewishammond.com/" target="_blank" rel="noopener noreferrer">Dr. Lewis Hammond</a>.</li>
          <li>I've got a series of pieces in the works on superintelligence deterrence (working with <a href="https://ari.us/team/morgan-c-plummer/" target="_blank" rel="noopener noreferrer">Morgan C. Plummer</a>). I also wrote about <a href="https://substack.com/home/post/p-183117624">managing US-ROK relations</a> amidst expanding export controls.</li>
          <li>I spent a year and change working on interpretability with Prof. <a href="https://pages.stat.wisc.edu/~zhong35/" target="_blank" rel="noopener noreferrer">Yiqiao Zhong</a> and Prof. <a href="https://junjiehu.github.io/" target="_blank" rel="noopener noreferrer">Junjie Hu</a>.</li>
          <li>In summer 2024, I completed the <a href="https://www.arena.education/" target="_blank" rel="noopener noreferrer">Alignment Research Engineer Accelerator</a> (ARENA) curriculum. I highly recommend others check it out, I've found no better way to quickly upskill in ML Safety.</li>
          <li>I advise <a href="https://secondlookresearch.com/" target="_blank" rel="noopener noreferrer">Second Look Research</a>, an organization focused on replicating AI safety research.</li>
          <li>I've given technical feedback and advice to many policy projects. I've also been told that I'm an excellent <a href="https://en.wikipedia.org/wiki/Rubber_duck_debugging" target="_blank" rel="noopener noreferrer">rubber duck</a>. If either of these services would be helpful, feel free to reach out!</li>
        </ul>
      </section>

      <hr class="rule" />

      <section class="publications">
        <h2>Publications</h2>
        <ol class="pub-list">
          <li>
            <span class="pub-title"><a href="https://arxiv.org/abs/2604.23459" target="_blank" rel="noopener noreferrer">Open Challenges in Multi-Agent Security: Towards Secure Systems of Interacting AI Agents</a></span>
            <span class="pub-authors">Christian Schroeder de Witt, Klaudia Krawiecka*, Igor Krawczuk*, Ben Hagag*, <strong>William L. Anderson*</strong>, et al.</span>
            <span class="pub-venue">arXiv preprint. * denotes major contributions.</span>
          </li>
          <li>
            <span class="pub-title"><a href="https://arxiv.org/abs/2604.23459" target="_blank" rel="noopener noreferrer">Architecture Matters for Multi-Agent Security</a></span>
            <span class="pub-authors">Ben Hagag, <strong>William L. Anderson</strong>, Christian Schroeder de Witt, Sarah Scheffler</span>
            <span class="pub-venue">ICML 2026</span>
          </li>
          <li>
            <span class="pub-title"><a href="https://arxiv.org/abs/2604.23065" target="_blank" rel="noopener noreferrer">What Should Frontier AI Developers Disclose About Internal Deployments?</a></span>
            <span class="pub-authors">Jacob Charnock*, Raja Mehta Moreno, Justin Miller, <strong>William L. Anderson</strong></span>
            <span class="pub-venue">Under Review, ICML TAIGR 2026</span>
          </li>
        </ol>
      </section>

      <hr class="rule" />

      <section>
        <h2>Talks</h2>
        <ul>
          <li><em>Organizer</em>, Research Process &amp; Technical AI Safety Workshops, AIMS Symposium, 2026</li>
          <li><em>Panelist</em>, Future of AI Panel, AIMS Symposium, 2026</li>
          <li><em>Multi-Agent Security Risks</em>, International Conference on Information Systems, 2025</li>
          <li><em>Panelist</em>, Wisconsin Technology Council Panel on AI Safety, 2025</li>
          <li><em>Diffuse Attacks on Multi-Agent AI Systems</em>, UChicago XLab Research Seminar, 2025</li>
          <li><em>A Case for Responsible AI</em>, IT Professionals Conference, 2025</li>
          <li><em>Sparse Models for Interpretability</em>, Yiqiao Zhong Summer Reading Group, 2025</li>
          <li><em>Security Risks in Multi-Agent AI Systems</em>, Advanced AI Congressional Exposition, 2025</li>
        </ul>
      </section>

      <hr class="rule" />

      <section>
        <h2>Awards &amp; Fellowships</h2>
        <ul>
          <li>2025 Summer Research Fellowship from UChicago XLab.</li>
          <li>2025–2026 Sophomore Research Fellowship from UW–Madison.</li>
          <li>2025 OpenPhil Action Fund University Organizer Fellowship.</li>
        </ul>
      </section>

      <p class="back-link"><a href="/">← Back to home</a></p>

      <footer class="site-footer">
        <p>© 2026 William L. Anderson</p>
      </footer>
    </main>

    <div id="note-popover" class="note-popover" role="tooltip"></div>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const popover = document.getElementById('note-popover');
        if (!popover) return;
        let hideTimer: number | null = null;

        function positionPopover(marker: Element) {
          const rect = marker.getBoundingClientRect();
          const popWidth = popover!.offsetWidth;
          const popHeight = popover!.offsetHeight;
          const scrollX = window.scrollX;
          const scrollY = window.scrollY;
          let left = rect.left + scrollX + rect.width / 2 - popWidth / 2;
          const top = rect.top + scrollY - popHeight - 10;
          const minLeft = scrollX + 8;
          const maxLeft = scrollX + document.documentElement.clientWidth - popWidth - 8;
          left = Math.max(minLeft, Math.min(maxLeft, left));
          popover!.style.left = left + 'px';
          popover!.style.top = top + 'px';
        }

        function showPopover(marker: Element) {
          if (hideTimer !== null) {
            clearTimeout(hideTimer);
            hideTimer = null;
          }
          popover!.textContent = marker.getAttribute('data-note') || '';
          popover!.classList.add('active');
          requestAnimationFrame(function () { positionPopover(marker); });
        }

        function scheduleHide() {
          if (hideTimer !== null) clearTimeout(hideTimer);
          hideTimer = window.setTimeout(function () {
            popover!.classList.remove('active');
            hideTimer = null;
          }, 300);
        }

        function cancelHide() {
          if (hideTimer !== null) {
            clearTimeout(hideTimer);
            hideTimer = null;
          }
        }

        document.querySelectorAll('sup.note').forEach(function (marker) {
          marker.addEventListener('mouseenter', function () { showPopover(marker); });
          marker.addEventListener('mouseleave', scheduleHide);
          marker.addEventListener('focus', function () { showPopover(marker); });
          marker.addEventListener('blur', scheduleHide);
        });

        popover.addEventListener('mouseenter', cancelHide);
        popover.addEventListener('mouseleave', scheduleHide);
      });
    </script>
  </body>
</html>
