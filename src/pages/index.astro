---
import '../styles/global.css';
import { Image } from 'astro:assets';
import Nav from '../components/Nav.astro';
import ThemeScript from '../components/ThemeScript.astro';
import profilePic from '../assets/me.jpg';
import favicon from '../assets/favicon.svg';
import favicon96 from '../assets/favicon-96x96.png';
import faviconIco from '../assets/favicon.ico';
import appleIcon from '../assets/apple-touch-icon.png';
import siteManifest from '../assets/site.webmanifest';
import faviconMats from '../assets/favicons/mats.png';
import faviconXlab from '../assets/favicons/xlab.ico?url';
import faviconWaisi from '../assets/favicons/waisi.png';
import faviconCoopAI from '../assets/favicons/cooperativeai.png';
import faviconWittLab from '../assets/favicons/wittlab.png';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <ThemeScript />
    <title>William L. Anderson</title>
    <link rel="icon" type="image/png" href={favicon96.src} sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <link rel="shortcut icon" href={faviconIco.src} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleIcon.src} />
    <link rel="manifest" href={siteManifest.src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="container">
      <header class="hero">
        <div class="hero-top">
          <div class="profile-pic">
            <Image src={profilePic} alt="William L. Anderson" width={320} height={320} />
          </div>
          <div class="hero-title">
            <h1>William L. Anderson</h1>
            <div id="email-container" class="email">
              <noscript>hello [at] wlanderson [dot] com</noscript>
            </div>
            <Nav />
          </div>
        </div>
        <div class="bio">
          <p>
            Hi, I’m Will! I work on making AI go well, because it seems like the best way to secure life, liberty, and the pursuit of happiness. I’m especially interested in the wicked, underrated problems in <a href="https://arxiv.org/abs/2502.14143" target="_blank" rel="noopener noreferrer">multi-agent safety</a> and <a href="https://www.cnas.org/publications/reports/promethean-rivalry" target="_blank" rel="noopener noreferrer">national security</a>. I’m starting soon as a Research Lead at the <a href="https://www.cooperativeai.com/foundation" target="_blank" rel="noopener noreferrer">Cooperative AI Foundation</a><img src={faviconCoopAI.src} alt="" class="org-favicon" aria-hidden="true" />, where I'll try to be a <a href="https://nanransohoff.substack.com/p/there-should-be-general-managers" target="_blank" rel="noopener noreferrer">general manager</a> for multi-agent risks. Before this, I was a <a href="https://www.matsprogram.org/" target="_blank" rel="noopener noreferrer">MATS</a><img src={faviconMats.src} alt="" class="org-favicon" aria-hidden="true" /> Fellow with the <a href="https://wittlab.ai/" target="_blank" rel="noopener noreferrer">Oxford Witt Lab</a><img src={faviconWittLab.src} alt="" class="org-favicon" aria-hidden="true" /> and a Research Fellow at <a href="https://xrisk.uchicago.edu/" target="_blank" rel="noopener noreferrer">UChicago XLab</a><img src={faviconXlab} alt="" class="org-favicon" aria-hidden="true" />. During my undergrad at UW–Madison, I was Director of the <a href="https://waisi.org/" target="_blank" rel="noopener noreferrer">Wisconsin AI Safety Initiative</a><img src={faviconWaisi.src} alt="" class="org-favicon" aria-hidden="true" /> and a Research Fellow with Prof. <a href="https://pages.stat.wisc.edu/~zhong35/" target="_blank" rel="noopener noreferrer">Yiqiao Zhong</a>. I have strong beliefs, weakly held, and update based on <a href="https://forms.gle/brAiMELagvQqUV1v9" target="_blank" rel="noopener noreferrer">feedback</a>.
          </p>
          <p>
            I like wearing <a href="/hats">many hats</a>, connecting people/communities (professionally and otherwise), giving technical feedback on policy work, and being a <a href="https://en.wikipedia.org/wiki/Rubber_duck_debugging" target="_blank" rel="noopener noreferrer">rubber duck</a>. If I can help (or be helped), please reach out!
          </p>
          <p>
            I grew up in Chanhassen, Minnesota, went to university in Madison, Wisconsin, and worked in Chicago, Illinois, Berkeley, California, and now London, England. I’m a fan of memorizing <a href="/poetry">sonnets</a>, collecting, swimming, &#123;Anki, Beli, Curius&#125;, good vegetarian food, being with friends, hiking, deeply inspecting leaves, PRs (lifting and code), getting too excited, <a href="https://aidanjs.com/blog/doubling/" target="_blank" rel="noopener noreferrer">doubling</a>, and <a href="https://eganphilosophy.com/wp-content/uploads/2022/05/Murdoch-The-Sovereignty-of-Good-Over-Other-Concepts.pdf" target="_blank" rel="noopener noreferrer">trying to do good</a>. Life is incredible. <a href="https://gladdestthing.com/poems/the-orange" target="_blank" rel="noopener noreferrer">I’m glad I exist</a>.
          </p>
        </div>
      </header>

      <hr class="rule ornament" />

      <p class="collections">
        <span class="collection-label">Mentors</span>
        <a href="https://lewishammond.com/" target="_blank" rel="noopener noreferrer">Dr. Lewis Hammond</a>,
        <a href="https://wittlab.ai/author/christian-schroeder-de-witt/" target="_blank" rel="noopener noreferrer">Dr. Christian Schroeder de Witt</a>,
        <a href="https://pages.stat.wisc.edu/~zhong35/" target="_blank" rel="noopener noreferrer">Prof. Yiqiao Zhong</a>,
        <a href="https://ari.us/team/morgan-c-plummer/" target="_blank" rel="noopener noreferrer">Morgan Plummer</a>,
        <a href="https://www.linkedin.com/in/john-bradley-059b4aa2/" target="_blank" rel="noopener noreferrer">John Bradley</a>.
        <span class="collection-label">Friends</span>
        <a href="https://www.cnas.org/people/ben-hayum" target="_blank" rel="noopener noreferrer">Ben</a>,
        <a href="https://jeremykintana.com/" target="_blank" rel="noopener noreferrer">Jeremy</a>,
        <a href="https://yixiong.dev/" target="_blank" rel="noopener noreferrer">Yixiong</a>,
        <a href="https://yeedrag.github.io/" target="_blank" rel="noopener noreferrer">Andy</a>,
        <a href="https://joneedssleep.github.io/" target="_blank" rel="noopener noreferrer">J-Train</a>,
        <a href="https://jasminexli.com/" target="_blank" rel="noopener noreferrer">J-Test</a>, <em>inter alia</em>.
        <span class="collection-label">Art</span>
        <a href="https://en.wikipedia.org/wiki/Impression,_Sunrise" target="_blank" rel="noopener noreferrer">Monet</a>, <a href="/poetry">Shakespeare</a>, <a href="https://www.tolkiensociety.org/discover/books-by-tolkien/" target="_blank" rel="noopener noreferrer">Tolkien</a>, <a href="https://www.youtube.com/watch?v=dQsjAbZDx-4" target="_blank" rel="noopener noreferrer">ABBA</a>, <a href="https://www.youtube.com/watch?v=ieRQyyPowH0" target="_blank" rel="noopener noreferrer">Ravel</a>, <a href="https://civilization.fandom.com/wiki/Shoshone_(Civ5)" target="_blank" rel="noopener noreferrer">Civilization V</a>, <a href="https://www.youtube.com/watch?v=JHFXG3r_0B8" target="_blank" rel="noopener noreferrer">Monty Python</a>, <a href="https://www.phys.ufl.edu/~thorn/grooks.html" target="_blank" rel="noopener noreferrer">Grooks</a>.
        <span class="collection-label">Inspirations</span>
        <a href="https://www.henrikkarlsson.xyz/p/unfolding" target="_blank" rel="noopener noreferrer">Henrik Karlsson</a>,
        <a href="https://nanransohoff.substack.com/i/184609883/lewis-bollard-factory-farming" target="_blank" rel="noopener noreferrer">Lewis Bollard</a>,
        <a href="https://turntrout.com/about" target="_blank" rel="noopener noreferrer">Alex Turner</a>,
        my grandfather,
        <a href="https://joecarlsmith.com/2023/02/17/seeing-more-whole/" target="_blank" rel="noopener noreferrer">Joe Carlsmith</a>,
        <a href="https://www.astralcodexten.com/p/being-john-rawls" target="_blank" rel="noopener noreferrer">Scott Alexander</a>, <a href="https://www.gutenberg.org/files/7370/old/trgov10h.htm" target="_blank" rel="noopener noreferrer">John Locke</a>.
      </p>

      <footer class="site-footer">
        <div class="site-chain">
          <a href="https://www.kaustubhais.com/">← Kaustubh</a>
          <a href="https://jeremykintana.com/">Jeremy →</a>
        </div>
        <p>© 2026 William L. Anderson</p>
      </footer>
    </main>

    <div id="note-popover" class="note-popover" role="tooltip"></div>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const emailContainer = document.getElementById('email-container');
        if (emailContainer) {
          const user = 'hello';
          const domain = 'wlanderson';
          const tld = 'com';
          const link = document.createElement('a');
          link.href = 'mailto:' + user + '@' + domain + '.' + tld;
          link.textContent = user + ' [at] ' + domain + ' [dot] ' + tld;
          emailContainer.innerHTML = '';
          emailContainer.appendChild(link);
        }

        const popover = document.getElementById('note-popover');
        if (!popover) return;
        let hideTimer: number | null = null;

        function positionPopover(marker: Element) {
          const rect = marker.getBoundingClientRect();
          const popWidth = popover!.offsetWidth;
          const popHeight = popover!.offsetHeight;
          const scrollX = window.scrollX;
          const scrollY = window.scrollY;
          let left = rect.left + scrollX + rect.width / 2 - popWidth / 2;
          const top = rect.top + scrollY - popHeight - 10;
          const minLeft = scrollX + 8;
          const maxLeft = scrollX + document.documentElement.clientWidth - popWidth - 8;
          left = Math.max(minLeft, Math.min(maxLeft, left));
          popover!.style.left = left + 'px';
          popover!.style.top = top + 'px';
        }

        function showPopover(marker: Element) {
          if (hideTimer !== null) {
            clearTimeout(hideTimer);
            hideTimer = null;
          }
          popover!.textContent = marker.getAttribute('data-note') || '';
          popover!.classList.add('active');
          requestAnimationFrame(function () { positionPopover(marker); });
        }

        function scheduleHide() {
          if (hideTimer !== null) clearTimeout(hideTimer);
          hideTimer = window.setTimeout(function () {
            popover!.classList.remove('active');
            hideTimer = null;
          }, 300);
        }

        function cancelHide() {
          if (hideTimer !== null) {
            clearTimeout(hideTimer);
            hideTimer = null;
          }
        }

        document.querySelectorAll('sup.note').forEach(function (marker) {
          marker.addEventListener('mouseenter', function () { showPopover(marker); });
          marker.addEventListener('mouseleave', scheduleHide);
          marker.addEventListener('focus', function () { showPopover(marker); });
          marker.addEventListener('blur', scheduleHide);
        });

        popover.addEventListener('mouseenter', cancelHide);
        popover.addEventListener('mouseleave', scheduleHide);
      });
    </script>
  </body>
</html>
