---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import favicon from '../assets/favicon.svg';
import favicon96 from '../assets/favicon-96x96.png';
import faviconIco from '../assets/favicon.ico';
import appleIcon from '../assets/apple-touch-icon.png';
import siteManifest from '../assets/site.webmanifest';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Now — William L. Anderson</title>
    <link rel="icon" type="image/png" href={favicon96.src} sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <link rel="shortcut icon" href={faviconIco.src} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleIcon.src} />
    <link rel="manifest" href={siteManifest.src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="container">
      <header class="subheader">
        <a href="/" class="subheader-name">William L. Anderson</a>
        <Nav />
      </header>

      <h1 class="page-title">What am I up to now?</h1>
      <p class="page-subtitle">Last updated 12/16/25, from my childhood home in Minnesota.</p>

      <div class="page-body">
        <p>This is a "<a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">now page</a>." You should make one too!</p>
        <p>I've just moved to London! I'll be here for the MATS extension and for my new role at the Cooperative AI Foundation, where I'll be leading a team.</p>
      </div>

      <p class="back-link"><a href="/">← Back to home</a></p>

      <footer class="site-footer">
        <p>© 2026 William L. Anderson</p>
      </footer>
    </main>
  </body>
</html>
